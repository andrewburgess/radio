{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | tr -d '\\r' | { read -r f; case \"$f\" in *.go) go fmt \"$f\" ;; esac; } 2>/dev/null || true",
            "statusMessage": "Running go fmt..."
          }
        ]
      }
    ]
  }
}
