# HTTP listen port
PORT=8080

# Path to SQLite database file
DB_PATH=radio.db

# Path to the librespot binary
LIBRESPOT_BIN=librespot

# Name shown in the Spotify Connect device list
LIBRESPOT_DEVICE_NAME=Zenith Radio

# Device type reported to Spotify (speaker, computer, smartphone, etc.)
LIBRESPOT_DEVICE_TYPE=speaker

# Directory for librespot credential/file cache
LIBRESPOT_CACHE_DIR=librespot-cache

# ALSA device for librespot audio output. Use `aplay -l` and
# `librespot --device ?` to find the right value for your hardware.
# 3.5mm jack on Pi 4: plughw:CARD=Headphones,DEV=0
# Leave empty to use librespot's default (often wrong on Pi without PulseAudio).
LIBRESPOT_AUDIO_DEVICE=plughw:CARD=Headphones,DEV=0

# Number of fixed dial station buckets
BUCKET_COUNT=12

# Spotify app credentials — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match the redirect URI configured in your Spotify app settings
SPOTIFY_REDIRECT_URI=http://localhost:8080/auth/callback

# Hardware (only meaningful on Pi builds — ignored by dev/mock builds)
# GPIO pin for the amplifier SD (shutdown) pin (High=on, Low=muted)
AMP_GPIO_PIN=GPIO26
# I2C bus and address for the TMAG5273 dial sensor
DIAL_I2C_BUS=I2C1
DIAL_I2C_ADDR=0x22
# Usable angular range of the tuning dial in degrees
DIAL_MIN_ANGLE=0
DIAL_MAX_ANGLE=270
# GPIO pins for the AM/AFC/FM 3-position toggle switch
# Row 1=GND, Row 2=PIN_A (AM/music), Row 3=PIN_B (AFC/speaker→FM/podcast), Row 4=GND
TOGGLE_GPIO_PIN_A=GPIO17
TOGGLE_GPIO_PIN_B=GPIO18
# GPIO pin for the volume knob power switch (High=on, Low=off — verify polarity)
POWER_GPIO_PIN=GPIO27
# SPI device and MCP3008 channel for the volume potentiometer
VOLUME_SPI_DEV=SPI0.0
VOLUME_SPI_CHANNEL=0
# Raw ADC values at the physical min/max pot positions (run cmd/volume-test to find these)
VOLUME_MIN_RAW=0
VOLUME_MAX_RAW=1023
# Maximum volume percentage output (caps full rotation to protect speakers)
VOLUME_MAX_PCT=80
# ALSA mixer control name — varies by DAC HAT (e.g. "Master", "Digital", "PCM")
ALSA_MIXER_CONTROL=Master

# Static audio
# Comma-separated list of MP3 files to use for no-signal buckets. One is chosen
# at random each time a static bucket is entered and looped until the bucket
# changes. Played directly by the Go binary via oto — no external tool required.
STATIC_AUDIO_FILES=static/noise.mp3

