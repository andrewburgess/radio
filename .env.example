# HTTP listen port
PORT=8080

# Path to SQLite database file
DB_PATH=radio.db

# Path to the librespot binary
LIBRESPOT_BIN=librespot

# Name shown in the Spotify Connect device list
LIBRESPOT_DEVICE_NAME=Zenith Radio

# Directory for librespot credential/file cache
LIBRESPOT_CACHE_DIR=librespot-cache

# Number of fixed dial station buckets
BUCKET_COUNT=12

# How many days back to look for podcast episodes
PODCAST_WINDOW_DAYS=14

# How often the podcast cron job runs (e.g. 6h, 30m)
PODCAST_CRON_INTERVAL=6h

# Spotify app credentials — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match the redirect URI configured in your Spotify app settings
SPOTIFY_REDIRECT_URI=http://localhost:8080/auth/callback

# Hardware (only meaningful on Pi builds — ignored by dev/mock builds)
# I2C bus and address for the TMAG5273 dial sensor
DIAL_I2C_BUS=I2C1
DIAL_I2C_ADDR=0x22
# Usable angular range of the tuning dial in degrees
DIAL_MIN_ANGLE=0
DIAL_MAX_ANGLE=270
# GPIO pin for the AM/FM toggle (High=music, Low=podcast — verify polarity)
TOGGLE_GPIO_PIN=GPIO17
# GPIO pin for the volume knob power switch (High=on, Low=off — verify polarity)
POWER_GPIO_PIN=GPIO27
# SPI device and MCP3008 channel for the volume potentiometer
VOLUME_SPI_DEV=SPI0.0
VOLUME_SPI_CHANNEL=0
# ALSA mixer control name — varies by DAC HAT (e.g. "Master", "Digital", "PCM")
ALSA_MIXER_CONTROL=Master

# File to persist Spotify OAuth tokens between restarts
SPOTIFY_TOKEN_FILE=spotify-tokens.json

# Phase 2 test: paste a Spotify playlist URI here, then hit GET /debug/play
# to verify the full librespot → Web API → radio time chain end-to-end.
# Remove once Phase 9 wires up the real station config.
SPOTIFY_TEST_PLAYLIST=
